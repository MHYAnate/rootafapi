async function run(model, input) {
  const response = await fetch(
    `https://api.cloudflare.com/client/v4/accounts/03d622597cb04278370ed358b3ca6df6/ai/run/${model}`,
    {
      headers: { Authorization: "Bearer cfut_JnZPhzw06ZNCEpiOLomkpusN7MOsbj3LDeKDDTeI5059b1d6" },
      method: "POST",
      body: JSON.stringify(input),
    }
  );
  const result = await response.json();
  return result;
}

